  { id: 1,  name: "计算机科学与技术",     category: "工学", hot: true,  avgSalary: "25-50万", description: "培养计算机软硬件系统设计与开发能力的高级人才。涵盖AI、大数据、网安等前沿方向。", courses: ["数据结构","操作系统","计算机网络","数据库","人工智能","软件工程","编译原理"], careers: ["软件工程师","算法工程师","数据科学家","AI研究员"], advice: "C9/985计算机毕业供不应求，优先选有国家重点实验室的院校。" },
  { id: 2,  name: "临床医学（八年制）",   category: "医学", hot: true,  avgSalary: "15-40万", description: "本博连读培养高层次医学人才。毕业授予医学博士学位，可直接进三甲医院。", courses: ["人体解剖学","生理学","病理学","药理学","内科学","外科学","儿科学"], careers: ["三甲医院主治医师","医学研究员","医学教授"], advice: "八年制只在顶尖医学院开设，竞争激烈。做好长期学习准备。" },
  { id: 3,  name: "口腔医学",             category: "医学", hot: true,  avgSalary: "15-35万", description: "培养口腔疾病预防、诊断和治疗的专业人才。就业面广，收入稳定。", courses: ["口腔解剖生理学","口腔组织病理学","牙体牙髓病学","口腔颌面外科学","口腔修复学"], careers: ["口腔医生","口腔正畸师","口腔修复师"], advice: "口腔就业前景好。川大华西口腔全国顶尖，分数要求极高。" },
  { id: 4,  name: "人工智能",             category: "工学", hot: true,  avgSalary: "30-60万", description: "新兴前沿学科，聚焦机器学习、深度学习、NLP、计算机视觉等方向。", courses: ["机器学习","深度学习","NLP","计算机视觉","强化学习","数据挖掘"], careers: ["AI算法工程师","ML工程师","NLP工程师","CV工程师"], advice: "AI是最热门方向之一，顶尖院校AI专业录取分极高。" },
  { id: 5,  name: "电子信息工程",         category: "工学", hot: true,  avgSalary: "18-35万", description: "培养电子技术和信息系统高级人才。涵盖通信、信号处理、集成电路等方向。", courses: ["信号与系统","数字电子技术","通信原理","电磁场","微处理器","DSP"], careers: ["硬件工程师","通信工程师","IC设计工程师","嵌入式工程师"], advice: "芯片行业人才缺口巨大。电子科大、东南大学相关专业实力强劲。" },
  { id: 6,  name: "电气工程及其自动化",   category: "工学", hot: false, avgSalary: "12-25万", description: "培养电力系统和自动化领域人才。就业稳定，国家电网是主要去向。", courses: ["电路原理","电机学","电力系统分析","自动控制","电力电子","高电压技术"], careers: ["电力工程师","自动化工程师","国家电网技术岗"], advice: "电气工程就业稳定性极高。华科、西交、清华电气全国前三。" },
  { id: 7,  name: "金融学",               category: "经济学", hot: false, avgSalary: "15-50万", description: "培养金融理论和业务技能兼备的高级人才。名校可进顶级投行和基金公司。", courses: ["微观经济学","宏观经济学","金融学","公司金融","投资学","金融工程"], careers: ["投行分析师","基金经理","风控经理","金融科技工程师"], advice: "金融行业高度看重学校背景，清北复交人是第一梯队。" },
  { id: 8,  name: "法学",                 category: "法学", hot: false, avgSalary: "10-40万", description: "培养法律知识和实务能力兼备的人才。名校法学可进顶级律所。", courses: ["法理学","宪法学","民法学","刑法学","商法学","国际法","诉讼法"], careers: ["律师","法官","检察官","法务总监"], advice: "五院四系是法学传统强校。通过法考是就业关键门槛。" },
  { id: 9,  name: "数学与应用数学",       category: "理学", hot: false, avgSalary: "15-40万", description: "基础学科，深造前景极好。数学功底是金融、AI、科研的核心竞争力。", courses: ["数学分析","高等代数","概率论","实变函数","泛函分析","微分方程"], careers: ["数学研究","量化分析师","数据科学家","精算师"], advice: "数学是万金油基础学科，转金融/AI/CS非常容易。" },
  { id: 10, name: "航空航天工程",         category: "工学", hot: false, avgSalary: "12-30万", description: "培养飞行器设计、制造和研究的高级人才。国防科技领域重要学科。", courses: ["空气动力学","飞行器结构力学","飞行力学","推进原理","航天器设计"], careers: ["航天工程师","飞行器设计师","航空研究员"], advice: "北航、哈工大、西工大是航空航天三巨头。" },
  { id: 11, name: "自动化",               category: "工学", hot: false, avgSalary: "15-30万", description: "培养控制系统分析与设计人才。涉及机器人、智能制造等前沿方向。", courses: ["自动控制原理","现代控制理论","信号与系统","计算机控制","机器人学"], careers: ["自动化工程师","控制工程师","机器人工程师"], advice: "自动化就业面广，可转CS/机器人/智能制造。" },
  { id: 12, name: "软件工程",             category: "工学", hot: true,  avgSalary: "20-45万", description: "培养软件系统设计、开发和管理的高级人才。更偏工程实践。", courses: ["软件工程导论","需求工程","软件体系结构","软件测试","DevOps"], careers: ["软件工程师","全栈工程师","技术经理"], advice: "软件工程就业市场需求旺盛，985毕业生起薪普遍较高。" },
  { id: 13, name: "信息安全",             category: "工学", hot: true,  avgSalary: "20-40万", description: "培养网络空间安全防护人才。国家战略需求，人才缺口超百万。", courses: ["密码学","网络安全","系统安全","渗透测试","安全协议"], careers: ["安全工程师","渗透测试工程师","安全架构师"], advice: "网络安全是国家战略需求，武大、电子科大信息安全实力强。" },
  { id: 14, name: "微电子科学与工程",     category: "工学", hot: true,  avgSalary: "20-45万", description: "集成电路/芯片设计核心专业。国家大力扶持，人才紧缺。", courses: ["半导体物理","集成电路设计","VLSI设计","模拟电路","EDA技术"], careers: ["IC设计工程师","芯片验证工程师","工艺工程师"], advice: "芯片行业是国家战略。清华、复旦、电子科大微电子全国领先。" },
  { id: 15, name: "数据科学与大数据技术", category: "工学", hot: true,  avgSalary: "22-45万", description: "大数据时代核心专业，培养数据分析、挖掘和应用的复合型人才。", courses: ["大数据处理","数据挖掘","机器学习","分布式计算","数据可视化"], careers: ["数据分析师","大数据工程师","数据产品经理"], advice: "大数据就业前景好，需扎实数学和编程基础。" },
  { id: 16, name: "生物医学工程",         category: "工学", hot: false, avgSalary: "12-25万", description: "交叉学科，融合工程技术与医学。医疗器械、生物信息学等方向前景好。", courses: ["生物力学","医学成像","生物材料","生理学","信号处理"], careers: ["医疗器械工程师","生物信息学研究员","医学影像工程师"], advice: "交叉学科优势明显，适合对医学和工程都感兴趣的考生。" },
  { id: 17, name: "物理学",               category: "理学", hot: false, avgSalary: "12-30万", description: "自然科学基础学科。培养扎实数理思维，转行金融/AI/工程均有优势。", courses: ["力学","电磁学","量子力学","热力学","固体物理","光学"], careers: ["物理研究","半导体研发","光学工程师","金融量化"], advice: "物理学是基础学科皇冠，深造前景好。中科大、北大、南大物理顶尖。" },
  { id: 18, name: "化学",                 category: "理学", hot: false, avgSalary: "10-20万", description: "传统基础学科，新能源/新材料方向前景好。深造比例高。", courses: ["有机化学","无机化学","物理化学","分析化学","高分子化学"], careers: ["化学研究","新材料研发","药企研发","化工工程师"], advice: "化学深造后就业前景明显提升。北大、南开化学实力强劲。" },
  { id: 19, name: "建筑学",               category: "工学", hot: false, avgSalary: "10-25万", description: "培养建筑设计和规划人才。学制五年，行业周期性明显。", courses: ["建筑设计","城市规划","建筑结构","建筑物理","中外建筑史"], careers: ["建筑设计师","城市规划师","室内设计师"], advice: "建筑老八校业内认可度最高。行业受经济周期影响较大。" },
  { id: 20, name: "机械工程",             category: "工学", hot: false, avgSalary: "10-22万", description: "传统工科核心专业。智能制造时代仍有大量需求。", courses: ["机械设计","机械制造","材料力学","流体力学","控制工程"], careers: ["机械工程师","制造工程师","自动化工程师"], advice: "机械工程是工业基础，就业稳定。华科、西交机械很强。" },
  { id: 21, name: "经济学",               category: "经济学", hot: false, avgSalary: "12-30万", description: "培养经济分析和政策研究人才。理论性强，深造后竞争力大增。", courses: ["微观经济学","宏观经济学","计量经济学","博弈论","产业经济学"], careers: ["经济分析师","政策研究员","咨询顾问"], advice: "经济学偏理论，名校背景很重要。人大、北大、复旦经济学领先。" },
